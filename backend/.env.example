ENV=dev
JWT_SECRET=change-me
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.d4blqpf.mongodb.net/
DATABASE_NAME=pre_onboarding

FRONTEND_URL=http://127.0.0.1:5173
BACKEND_URL=http://127.0.0.1:8001

# OAuth provider credentials. Configure these in each provider console with:
# http://127.0.0.1:8001/api/auth/oauth/google/callback
# http://127.0.0.1:8001/api/auth/oauth/microsoft/callback
# http://127.0.0.1:8001/api/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Keep these for company deployment compatibility when MONGODB_URI is not set.
# mongo_username=
# mongo_password=
# MONGO_HOST=
# MONGO_PORT=27017
# DB_NAME_DEV=
# DB_NAME_PROD=

# OpenAI-compatible model gateway
openai_api_base=https://neuroverse.tatamotors.com/monitoring_v2/v1
openai_api_key=
model_name_llm=neuroverse-meta-llama--Llama-3.1-8B-Instruct
router_model_name=neuroverse-gpt-oss-120b
vision_model_name=neuroverse-Qwen2.5-VL-72B-Instruct
code_model_name=neuroverse-gpt-oss-120b

# Embeddings / retrieval
allMini_emb_api=https://neuroverse.tatamotors.com/monitoring_v2/v1/embeddings
model_name_emb=neuroverse-all-MiniLM-L6-v2
milvus_base=
milvus_port=19530
milvus_user=
milvus_password=
vector_db_name=
collection_name=Pre-onboarding
retrieval_api=

# Speech services
STT_API_URL=https://neuroverse.tatamotors.com/code-stt/transcribe_audio
TTS_API_URL=https://neuroverse.tatamotors.com/code-tts/text_to_speech
